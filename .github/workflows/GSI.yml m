name: Build GSI with ErfanGSIs

on:
  workflow_dispatch:
    inputs:
      rom_url:
        description: 'ROM 刷机包直链 (.zip / .tgz)'
        required: true
      rom_type:
        description: 'ROM 类型 (如 MIUI, ColorOS, OneUI)'
        required: true
        default: 'Generic'
      output_type:
        description: '输出分区类型 (all / ab / a)'
        required: true
        default: 'ab'
        type: choice
        options:
          - all
          - ab
          - a

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: 安装系统依赖
        run: |
          sudo apt update
          sudo apt install -y git wget unzip xz-utils lzip e2fsprogs \
            android-sdk-libsparse-utils liblzma-dev lz4 tar gcc make \
            golang-go pigz brotli
          git clone https://github.com/xpirt/sdat2img.git /tmp/sdat2img

      - name: 设置 Python 3.9
        uses: actions/setup-python@v5
        with:
          python-version: '3.9'

      - name: 安装 Python 依赖
        run: |
          python -m pip install --upgrade pip
          pip install docopt protobuf pycryptodome backports.lzma

      - name: 克隆 ErfanGSIs 并初始化子模块
        run: |
          git clone --recurse-submodules https://github.com/erfanoabdi/ErfanGSIs.git
          cd ErfanGSIs
          git submodule update --init --recursive
          if [ -f "tools/Firmware_extractor/zui/packsparseimg.go" ]; then
            cd tools/Firmware_extractor/zui/
            go build packsparseimg.go
            chmod +x packsparseimg
            cd ../../../
          fi
          chmod +x url2GSI.sh make.sh 2>/dev/null || true

      - name: 下载并预处理 ROM（转换 system.img，添加 Treble 属性）
        run: |
          mkdir -p raw_rom
          cd raw_rom
          wget -O input.pkg "${{ github.event.inputs.rom_url }}"
          if file input.pkg | grep -q "gzip compressed"; then
            mv input.pkg input.tgz
            tar -xzf input.tgz
          elif file input.pkg | grep -q "Zip archive"; then
            mv input.pkg input.zip
            unzip input.zip
          else
            echo "无法识别的压缩包格式"
            exit 1
          fi
          
          # 查找 system.img
          SYSTEM_IMG=$(find . -name "system.img" | head -n 1)
          if [ -z "$SYSTEM_IMG" ]; then
            SYSTEM_DAT=$(find . -name "system.new.dat" | head -n 1)
            if [ -n "$SYSTEM_DAT" ]; then
              TRANSFER_LIST=$(find . -name "system.transfer.list" | head -n 1)
              python3 /tmp/sdat2img/sdat2img.py "$TRANSFER_LIST" "$SYSTEM_DAT" system.img
              SYSTEM_IMG="system.img"
            else
              echo "未找到 system.img 或 system.new.dat"
              exit 1
            fi
          fi
          
          cp "$SYSTEM_IMG" system.raw
          if file system.raw | grep -q "Android sparse image"; then
            simg2img system.raw system.img.raw
            mv system.img.raw system.raw
          fi
          
          sudo e2fsck -fy system.raw || true
          sudo resize2fs -M system.raw
          mkdir -p mnt_system
          sudo mount -o rw,loop system.raw mnt_system
          
          if [ -f mnt_system/system/build.prop ]; then
            BUILD_PROP="mnt_system/system/build.prop"
          elif [ -f mnt_system/build.prop ]; then
            BUILD_PROP="mnt_system/build.prop"
          else
            sudo umount mnt_system
            exit 1
          fi
          
          if ! sudo grep -q "ro.treble.enabled" "$BUILD_PROP"; then
            echo "添加 Treble 属性..."
            echo "ro.treble.enabled=true" | sudo tee -a "$BUILD_PROP"
            echo "ro.product.first_api_level=28" | sudo tee -a "$BUILD_PROP"
            echo "ro.product.vndk.version=28" | sudo tee -a "$BUILD_PROP"
          fi
          
          sudo umount mnt_system
          sudo e2fsck -fy system.raw || true
          sudo resize2fs -M system.raw
          
          cp system.raw final_system.img
          cd ..

      - name: 为 ErfanGSIs 准备输入（打包 + 预置 build.prop）
        run: |
          cd ErfanGSIs
          # 打包成 zip（根目录放 system.img）
          mkdir -p input_pkg
          cp ../raw_rom/final_system.img input_pkg/system.img
          cd input_pkg
          zip -r ../input_custom.zip .
          cd ..
          # 预置 build.prop 到 tmp 目录，让 ErfanGSIs 检查通过
          mkdir -p tmp/system/system
          mkdir -p mnt_system
          sudo mount -o ro ../raw_rom/final_system.img mnt_system
          if [ -f mnt_system/system/build.prop ]; then
            sudo cp mnt_system/system/build.prop tmp/system/system/build.prop
          elif [ -f mnt_system/build.prop ]; then
            sudo cp mnt_system/build.prop tmp/system/system/build.prop
          else
            sudo umount mnt_system
            exit 1
          fi
          sudo umount mnt_system
          echo "预置 build.prop 完成"

      - name: 使用 ErfanGSIs 生成 GSI
        run: |
          cd ErfanGSIs
          bash url2GSI.sh input_custom.zip "${{ github.event.inputs.rom_type }}" ${{ github.event.inputs.output_type }}

      - name: 上传 GSI 镜像
        uses: actions/upload-artifact@v4
        with:
          name: ErfanGSI-output
          path: ErfanGSIs/output/*.img
